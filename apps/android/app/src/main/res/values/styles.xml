<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="flux">
        <item name="android:textSize">30sp</item>
        <item name="android:textColor">#000000</item>
    </style>

    <style name="fav_tv">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#99000000</item>
    </style>

    <style name="tabs">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">#000000</item>
    </style>

    <!-- Makes ShapeableImageView circular -->
    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="chat_name">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#000000</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="chat_last_message">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">#99000000</item>
    </style>

    <style name="chat_time">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">#99000000</item>
    </style>

    <style name="Widget.App.Button.Base" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:fontFamily">@font/nunito_sans</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">#FF000000</item>
    </style>

    <style name="Widget.App.Button.TextButton" parent="Widget.App.Button.Base">
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Widget.App.Button.Filled" parent="Widget.App.Button.Base">
        <item name="android:backgroundTint">#FFFFFFFF</item>
        <item name="strokeColor">#FFE0E0E0</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.App.Button.Rounded" parent="Widget.App.Button.Filled">
        <item name="cornerRadius">32.5dp</item>
    </style>

    <style name="Widget.App.Button.Action" parent="Widget.App.Button.WithIcon">
        <item name="strokeColor">@color/btn_login_stroke</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:stateListAnimator">@animator/btn_elevation</item>
    </style>

    <style name="Widget.App.Button.WithIcon" parent="Widget.App.Button.Rounded">
        <item name="iconGravity">start</item>
        <item name="iconSize">24dp</item>
        <item name="iconPadding">16dp</item>
    </style>

    <style name="Widget.App.Button.Circular" parent="Widget.App.Button.Filled">
        <item name="cornerRadius">100dp</item>
    </style>

    <!-- Full-width icon+text row; set app:icon + android:text in the layout -->
    <style name="Widget.App.Button.Row" parent="Widget.App.Button.Base">
        <item name="android:backgroundTint">@android:color/transparent</item>
        <item name="strokeWidth">0dp</item>
        <item name="cornerRadius">0dp</item>
        <item name="iconGravity">start</item>
        <item name="iconSize">24dp</item>
        <item name="iconPadding">12dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:gravity">start|center_vertical</item>
    </style>

    <!-- Icon-only circular button; set size + app:icon in the layout -->
    <style name="Widget.App.Button.Icon" parent="Widget.App.Button.Circular">
        <item name="android:backgroundTint">#40FFFFFF</item>
        <item name="strokeWidth">0dp</item>
        <item name="iconPadding">0dp</item>
        <item name="iconGravity">textStart</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <!-- Removes default background from BottomSheetDialog so bg_bottom_sheet shows correctly -->
    <style name="BottomSheetStyle" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetModalStyle</item>
    </style>

    <style name="BottomSheetModalStyle" parent="Widget.Material3.BottomSheet.Modal">
        <item name="backgroundTint">@android:color/transparent</item>
    </style>

    <style name="Widget.Theme.Flux.MyView" parent="">
        <item name="android:background">@color/gray_400</item>
        <item name="exampleColor">@color/light_blue_400</item>
    </style>
</resources>