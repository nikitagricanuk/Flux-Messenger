<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="flux">
        <item name="android:textSize">30sp</item>
        <item name="android:textColor">#000000</item>
    </style>
    <style name="fav_tv">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#99000000</item>
    </style>
    <style name="tabs">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">#000000</item>
    </style>

    <!-- Makes ShapeableImageView circular -->
    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="chat_name">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#000000</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="chat_last_message">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">#99000000</item>
    </style>

    <style name="chat_time">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">#99000000</item>
    </style>

    <style name="Widget.App.Button.FluxButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:backgroundTint">#FFFFFFFF</item>
        <item name="android:textColor">#FF000000</item>
        <item name="android:fontFamily">@font/nunito_sans</item>
        <item name="android:textSize">16sp</item>
        <item name="cornerRadius">32.5dp</item>
        <item name="strokeColor">#FFE0E0E0</item>
        <item name="strokeWidth">1dp</item>
        <item name="iconGravity">start</item>
        <item name="iconSize">24dp</item>
        <item name="iconPadding">16dp</item>
    </style>

    <!-- Removes default background from BottomSheetDialog so bg_bottom_sheet shows correctly -->
    <style name="BottomSheetStyle" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetModalStyle</item>
    </style>
    <style name="BottomSheetModalStyle" parent="Widget.Material3.BottomSheet.Modal">
        <item name="backgroundTint">@android:color/transparent</item>
    </style>
</resources>