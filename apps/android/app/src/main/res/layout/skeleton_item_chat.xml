<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <View
        android:id="@+id/skeletonAvatar"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/bg_skeleton_circle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <View
        android:id="@+id/skeletonName"
        android:layout_width="140dp"
        android:layout_height="14dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_skeleton_rect"
        app:layout_constraintStart_toEndOf="@id/skeletonAvatar"
        app:layout_constraintEnd_toStartOf="@id/skeletonTime"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintHorizontal_bias="0" />

    <View
        android:id="@+id/skeletonMessage"
        android:layout_width="0dp"
        android:layout_height="12dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_skeleton_rect"
        app:layout_constraintStart_toEndOf="@id/skeletonAvatar"
        app:layout_constraintEnd_toStartOf="@id/skeletonTime"
        app:layout_constraintTop_toBottomOf="@id/skeletonName" />

    <View
        android:id="@+id/skeletonTime"
        android:layout_width="36dp"
        android:layout_height="12dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_skeleton_rect"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>