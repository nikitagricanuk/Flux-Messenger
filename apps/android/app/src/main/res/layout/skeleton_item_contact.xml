<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:layout_marginBottom="8dp"
    android:padding="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_contact_card_for_page">

        <View
            android:id="@+id/skeletonAvatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_skeleton_circle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <View
            android:id="@+id/skeletonName"
            android:layout_width="130dp"
            android:layout_height="14dp"
            android:layout_marginStart="11dp"
            android:background="@drawable/bg_skeleton_rect"
            app:layout_constraintStart_toEndOf="@id/skeletonAvatar"
            app:layout_constraintEnd_toStartOf="@id/skeletonIcon"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/skeletonPhone"
            app:layout_constraintHorizontal_bias="0" />

        <View
            android:id="@+id/skeletonPhone"
            android:layout_width="90dp"
            android:layout_height="12dp"
            android:layout_marginStart="11dp"
            android:background="@drawable/bg_skeleton_rect"
            app:layout_constraintStart_toEndOf="@id/skeletonAvatar"
            app:layout_constraintEnd_toStartOf="@id/skeletonIcon"
            app:layout_constraintTop_toBottomOf="@id/skeletonName"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintHorizontal_bias="0" />

        <View
            android:id="@+id/skeletonIcon"
            android:layout_width="36dp"
            android:layout_height="28dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_skeleton_rect"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>