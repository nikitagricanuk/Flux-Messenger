<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet">

    <!-- Header: cancel button + centred title -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="20dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <ru.flux.android.core.views.button.BaseButton
            android:id="@+id/cancelButton"
            style="@style/Widget.App.Button.Icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:contentDescription="@null"
            app:icon="@drawable/cross"
            app:iconTint="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/nunito_sans"
            android:text="@string/new_message"
            android:textColor="#000000"
            android:textSize="20sp" />

    </RelativeLayout>

    <!-- Scrollable body: action rows + alphabetical contacts -->

    <ru.flux.android.core.views.button.BaseButton
        android:id="@+id/newGroupButton"
        style="@style/Widget.App.Button.Row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:text="@string/new_group"
        app:icon="@drawable/users"
        app:iconTint="@null" />

    <ru.flux.android.core.views.button.BaseButton
        android:id="@+id/newContactButton"
        style="@style/Widget.App.Button.Row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"
        android:text="@string/new_contact"
        app:icon="@drawable/user"
        app:iconTint="@null" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/contactsRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="32dp" />

</LinearLayout>
